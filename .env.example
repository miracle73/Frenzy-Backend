# App
NODE_ENV=development
PORT=3000

# API_URL=http://localhost:4000

# Auth
JWT_SECRET=primlook_super_secret_key
JWT_EXPIRES_IN=24h
# FRONTEND_URL is only used for the legacy link-based password reset email (primlook-fe).
# Mobile apps do NOT need this — they use OTP-based reset and send their own payment callbackUrl.
FRONTEND_URL=
# FRONTEND_URL=https://primlook-fe-test.vercel.app
# URL of the web app where vendor-booking payment verification redirects to
VENDOR_PAYMENT_CALLBACK_URL=http://localhost:3000

# SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# GMAIL CREDENTIALS
# EMAIL_SENDER_PASS=
# EMAIL_SENDER_NAME=

# PRIMLOOK CREDENTIALS
# SECOND_EMAIL_SENDER_PASS=
# SECOND_EMAIL_SENDER_NAME=

# CLOUDINARY CREDENTIALS
CLOUDINARY_CLOUDNAME=dnvlmdpam
CLOUDINARY_APIKEY=
CLOUDINARY_APISECRET=

# PAYSTACK CREDENTIALS
PAYSTACK_BASE_URL=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# Payment Configuration
ENABLE_PAYMENT=true

# OTP + Password Reset
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_VERIFIED_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=15

# CORS (comma-separated list, leave empty to allow all)
CORS_ORIGINS=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/primlook?schema=public

# PORT=4000
# MONGOUSER=primlook
# MONGOPASSWORD=35crZinIXYM7MxP0
# MONGOAPPNAME=primlook-fe