# Database (PostgreSQL for production)
DATABASE_URL=postgresql://storekeeper:storekeeper_pass@localhost:5432/storekeeper_db

# PostgreSQL Docker settings
POSTGRES_USER=storekeeper
POSTGRES_PASSWORD=storekeeper_pass
POSTGRES_DB=storekeeper_db

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# CORS (comma-separated frontend URLs)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# AI/ML - OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
AI_MODEL=google/gemini-2.5-flash-preview
